generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  ADMIN_MENTOR
  ADMIN_AKADEMIK
  MENTOR
  AKADEMIK
  GURU
  MURID
  WALI_MURID
  USER_BIASA
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum LoginEventProvider {
  GOOGLE
  EMAIL
}

enum CourseStatus {
  DRAFT
  REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVEL
}

enum LessonType {
  VIDEO
  ARTICLE
  QUIZ
  ASSIGNMENT
  LIVE_SESSION
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
}

enum MediaOwnerType {
  COURSE
  MODULE
  LESSON
  REVIEW
  COMMENT
  PROFILE
}

enum EnrollmentSource {
  PURCHASED
  ASSIGNED
  FREE
  MIGRATION
}

enum EnrollmentStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  REFUNDED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  COMPLETED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum PaymentGateway {
  MIDTRANS
  XENDIT
  DUITKU
  MANUAL
}

enum PaymentMethod {
  BANK_TRANSFER
  E_WALLET
  QRIS
  CREDIT_CARD
  MANUAL_TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
  REJECTED
}

enum CommentStatus {
  PUBLISHED
  HIDDEN
  DELETED
}

enum NotificationType {
  PAYMENT_SUCCESS
  COURSE_ENROLLED
  COURSE_ASSIGNED
  COURSE_COMMENT
  LESSON_REPLY
  CERTIFICATE_ISSUED
  ADMIN_NOTICE
}

enum AuditAction {
  USER_CREATE
  USER_UPDATE
  USER_SUSPEND

  COURSE_CREATE
  COURSE_UPDATE
  COURSE_SUBMIT_REVIEW
  COURSE_PUBLISH
  COURSE_REJECT

  ORDER_CREATE
  ORDER_UPDATE
  PAYMENT_UPDATE

  ENROLLMENT_CREATE
  ENROLLMENT_ASSIGN
  ENROLLMENT_CANCEL

  REVIEW_MODERATE
  COMMENT_MODERATE
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String
  normalizedEmail String    @unique
  emailVerified   DateTime?
  password        String?
  phone           String?   @unique
  phoneVerifiedAt DateTime?
  image           String?
  imagePublicId   String?

  role   UserRole   @default(USER_BIASA)
  status UserStatus @default(ACTIVE)

  bio         String?
  headline    String?
  websiteUrl  String?
  socialLinks Json?

  createdById  String?
  createdBy    User?   @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers User[]  @relation("UserCreatedBy")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  accounts     Account[]
  authSessions AuthSession[]
  loginEvents  LoginEvent[]

  mentorProfile   MentorProfile?
  guruProfile     GuruProfile?
  muridProfile    MuridProfile?
  waliProfile     WaliMuridProfile?
  academicProfile AcademicProfile?

  coursesCreated Course[] @relation("CourseCreator")

  enrollments         Enrollment[] @relation("UserEnrollments")
  assignedEnrollments Enrollment[] @relation("EnrollmentAssignedBy")

  orders   Order[]
  payments Payment[]

  lessonProgress LessonProgress[]

  courseReviews CourseReview[]
  reviewReplies ReviewReply[]

  comments       Comment[]
  commentReplies CommentReply[]

  courseLikes CourseLike[]
  lessonLikes LessonLike[]
  wishlists   Wishlist[]

  certificates  Certificate[]
  notifications Notification[]

  auditLogs AuditLog[] @relation("AuditActor")

  muridAsWali MuridProfile[] @relation("WaliMuridRelation")

  @@index([role])
  @@index([status])
  @@index([createdById])
  @@index([deletedAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String @map("provider_account_id")

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model AuthSession {
  id               String    @id
  userId           String
  refreshTokenHash String
  tokenVersion     Int       @default(1)
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model LoginEvent {
  id        String             @id @default(cuid())
  userId    String?
  email     String?
  provider  LoginEventProvider
  success   Boolean            @default(true)
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime           @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([email, createdAt])
}

model MentorProfile {
  id     String @id @default(cuid())
  userId String @unique

  expertise String?
  bio       String? @db.Text
  linkedin  String?
  portfolio String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GuruProfile {
  id     String @id @default(cuid())
  userId String @unique

  nip     String?
  subject String?
  bio     String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AcademicProfile {
  id     String @id @default(cuid())
  userId String @unique

  position String?
  division String?
  note     String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MuridProfile {
  id     String @id @default(cuid())
  userId String @unique

  nis     String?
  kelas   String?
  jurusan String?

  waliId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  wali User? @relation("WaliMuridRelation", fields: [waliId], references: [id], onDelete: SetNull)

  @@index([waliId])
  @@index([kelas])
}

model WaliMuridProfile {
  id     String @id @default(cuid())
  userId String @unique

  pekerjaan String?
  alamat    String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id   String @id @default(cuid())
  name String
  slug String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses Course[]

  @@index([name])
}

model Course {
  id        String @id @default(cuid())
  creatorId String

  title       String
  slug        String  @unique
  subtitle    String?
  description String? @db.Text

  status CourseStatus @default(DRAFT)
  level  CourseLevel  @default(ALL_LEVEL)

  categoryId String?
  language   String  @default("id")

  price     Decimal  @db.Decimal(12, 2)
  salePrice Decimal? @db.Decimal(12, 2)
  isFree    Boolean  @default(false)

  requirements String[] @default([])
  outcomes     String[] @default([])
  targetUsers  String[] @default([])

  totalDurationSec Int @default(0)
  totalLessons     Int @default(0)

  publishedAt  DateTime?
  rejectedAt   DateTime?
  rejectReason String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  creator  User      @relation("CourseCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  modules Module[]
  lessons Lesson[]
  media   Media[]

  orderItems  OrderItem[]
  enrollments Enrollment[]

  reviews      CourseReview[]
  likes        CourseLike[]
  wishlists    Wishlist[]
  certificates Certificate[]

  @@index([creatorId])
  @@index([categoryId])
  @@index([status])
  @@index([deletedAt])
}

model Module {
  id       String @id @default(cuid())
  courseId String

  title     String
  summary   String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  media   Media[]

  @@index([courseId, sortOrder])
}

model Lesson {
  id       String @id @default(cuid())
  courseId String
  moduleId String

  title       String
  slug        String
  description String?
  type        LessonType @default(VIDEO)

  content     String? @db.Text
  videoUrl    String?
  durationSec Int?

  sortOrder   Int     @default(0)
  isPreview   Boolean @default(false)
  isPublished Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  media    Media[]
  progress LessonProgress[]
  comments Comment[]
  likes    LessonLike[]

  @@unique([courseId, slug])
  @@index([courseId])
  @@index([moduleId, sortOrder])
  @@index([deletedAt])
}

model Media {
  id String @id @default(cuid())

  type      MediaType
  ownerType MediaOwnerType

  url         String
  publicId    String?
  filename    String?
  mimeType    String?
  sizeBytes   Int?
  durationSec Int?

  alt       String?
  caption   String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)

  courseId  String?
  moduleId  String?
  lessonId  String?
  reviewId  String?
  commentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course?       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module  Module?       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lesson  Lesson?       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  review  CourseReview? @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  comment Comment?      @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([courseId, sortOrder])
  @@index([moduleId, sortOrder])
  @@index([lessonId, sortOrder])
  @@index([reviewId])
  @@index([commentId])
  @@index([ownerType])
}

model Order {
  id   String @id @default(cuid())
  code String @unique

  userId String
  status OrderStatus @default(PENDING_PAYMENT)

  subtotal Decimal @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)

  couponCode String?
  notes      String?

  expiresAt   DateTime?
  paidAt      DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  items       OrderItem[]
  payment     Payment?
  refund      RefundRequest?
  enrollments Enrollment[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id       String @id @default(cuid())
  orderId  String
  courseId String

  titleSnapshot String
  price         Decimal @db.Decimal(12, 2)
  discount      Decimal @default(0) @db.Decimal(12, 2)
  lineTotal     Decimal @db.Decimal(12, 2)

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Restrict)

  @@unique([orderId, courseId])
  @@index([courseId])
}

model Payment {
  id      String @id @default(cuid())
  orderId String @unique
  userId  String

  method PaymentMethod
  status PaymentStatus @default(PENDING)
  amount Decimal       @db.Decimal(12, 2)

  gateway              PaymentGateway
  channelCode          String?
  gatewayReference     String?        @unique
  paymentUrl           String?
  gatewayStatusCode    String?
  gatewayStatusMessage String?

  callbackPayload Json?
  callbackAt      DateTime?

  proofUrl String?
  paidAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([status, createdAt])
  @@index([method])
}

model Enrollment {
  id String @id @default(cuid())

  userId   String
  courseId String
  orderId  String?

  source EnrollmentSource @default(PURCHASED)
  status EnrollmentStatus @default(ACTIVE)

  assignedById String?
  assignedAt   DateTime?

  startedAt   DateTime  @default(now())
  expiredAt   DateTime?
  completedAt DateTime?

  progressPercent Decimal @default(0) @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation("UserEnrollments", fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  assignedBy User? @relation("EnrollmentAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([orderId])
  @@index([source])
  @@index([status])
  @@index([assignedById])
}

model LessonProgress {
  id String @id @default(cuid())

  userId   String
  lessonId String

  watchedSec   Int       @default(0)
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  lastAccessAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
  @@index([userId, updatedAt])
}

model Comment {
  id String @id @default(cuid())

  lessonId String
  userId   String

  message String        @db.Text
  status  CommentStatus @default(PUBLISHED)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  replies CommentReply[]
  media   Media[]

  @@index([lessonId, createdAt])
  @@index([userId, createdAt])
  @@index([status])
  @@index([deletedAt])
}

model CommentReply {
  id String @id @default(cuid())

  commentId String
  userId    String

  message String @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([commentId, createdAt])
  @@index([userId, createdAt])
  @@index([deletedAt])
}

model CourseReview {
  id String @id @default(cuid())

  courseId String
  userId   String

  rating  Int
  comment String?      @db.Text
  status  ReviewStatus @default(PENDING)

  moderationReason String?
  moderatedAt      DateTime?
  moderatedBy      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  replies ReviewReply[]
  media   Media[]

  @@unique([courseId, userId])
  @@index([courseId, status, createdAt])
  @@index([userId, createdAt])
  @@index([deletedAt])
}

model ReviewReply {
  id String @id @default(cuid())

  reviewId String
  actorId  String

  message String @db.Text

  createdAt DateTime @default(now())

  review CourseReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  actor  User         @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([reviewId, createdAt])
  @@index([actorId, createdAt])
}

model CourseLike {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, createdAt])
}

model LessonLike {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId, createdAt])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model Coupon {
  id   String @id @default(cuid())
  code String @unique
  name String

  discountPercent Int?
  discountAmount  Decimal? @db.Decimal(12, 2)

  maxUsage  Int?
  usedCount Int  @default(0)

  startsAt DateTime?
  endsAt   DateTime?
  isActive Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([startsAt, endsAt])
}

model RefundRequest {
  id      String @id @default(cuid())
  orderId String @unique

  reason       String
  reasonDetail String? @db.Text
  status       String  @default("REQUESTED")

  amount Decimal? @db.Decimal(12, 2)
  note   String?  @db.Text

  requestedAt DateTime  @default(now())
  reviewedAt  DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model Certificate {
  id String @id @default(cuid())

  userId   String
  courseId String

  certificateNo   String   @unique
  issuedAt        DateTime @default(now())
  fileUrl         String?
  verificationUrl String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model Notification {
  id     String @id @default(cuid())
  userId String

  type    NotificationType
  title   String
  message String?
  data    Json?

  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([type, createdAt])
}

model AuditLog {
  id String @id @default(cuid())

  actorId String?
  action  AuditAction

  entity   String
  entityId String?

  metadata  Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([entity, entityId])
}
