generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  BANNED
}
enum RoleScope {
  INSIDIA
  MITRA
}
enum MitraType {
  KAMPUS
  SEKOLAH
}
enum AcademicStatus {
  ACTIVE
  INACTIVE
}
enum LoginEventProvider {
  GOOGLE
  EMAIL
}

enum CourseStatus {
  DRAFT
  REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVEL
}

enum LessonType {
  VIDEO
  ARTICLE
  QUIZ
  ASSIGNMENT
  LIVE_SESSION
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
}

enum MediaOwnerType {
  COURSE
  MODULE
  LESSON
  REVIEW
  COMMENT
  PROFILE
}

enum EnrollmentSource {
  PURCHASED
  ASSIGNED
  FREE
  MIGRATION
}

enum EnrollmentStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  REFUNDED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  COMPLETED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum PaymentGateway {
  MIDTRANS
  XENDIT
  DUITKU
  MANUAL
}

enum PaymentMethod {
  BANK_TRANSFER
  E_WALLET
  QRIS
  CREDIT_CARD
  MANUAL_TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
  REJECTED
}

enum CommentStatus {
  PUBLISHED
  HIDDEN
  DELETED
}

enum NotificationType {
  PAYMENT_SUCCESS
  COURSE_ENROLLED
  COURSE_ASSIGNED
  COURSE_COMMENT
  LESSON_REPLY
  CERTIFICATE_ISSUED
  ADMIN_NOTICE
}

enum AuditAction {
  USER_CREATE
  USER_UPDATE
  USER_SUSPEND

  COURSE_CREATE
  COURSE_UPDATE
  COURSE_SUBMIT_REVIEW
  COURSE_PUBLISH
  COURSE_REJECT

  ORDER_CREATE
  ORDER_UPDATE
  PAYMENT_UPDATE

  ENROLLMENT_CREATE
  ENROLLMENT_ASSIGN
  ENROLLMENT_CANCEL

  REVIEW_MODERATE
  COMMENT_MODERATE
}
enum BulkUploadJobStatus {
  VALIDATED
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum BulkUploadRowStatus {
  VALID
  INVALID
  SUCCESS
  FAILED
  SKIPPED
}
model User {
  id              String    @id @default(cuid())
  name            String?
  email           String
  normalizedEmail String    @unique
  emailVerified   DateTime?
  password        String?
  phone           String?   @unique
  phoneVerifiedAt DateTime?
  image           String?
  imagePublicId   String?

  insidiaRole UserInsidiaRole?
  status UserStatus @default(ACTIVE)

  bio         String?
  websiteUrl  String?
  socialLinks Json?

  createdById  String?
  createdBy    User?   @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers User[]  @relation("UserCreatedBy")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
 mitraRoles   UserMitraRole?
  accounts     Account[]
  authSessions AuthSession[]
  loginEvents  LoginEvent[]

  mentorProfile   MentorProfile?
  guruProfile     GuruProfile?
  muridProfile    MuridProfile?
  waliProfile     WaliMuridProfile?
  academicProfile AcademicProfile?
  waliClassGroups ClassGroup[] @relation("ClassGroupHomeroomTeacher")
  classGroupCoursesAsTeacher ClassGroupCourse[] @relation("ClassGroupCourseTeacher")
  classGroupStudents ClassGroupStudent[] @relation("ClassGroupStudentUser")
  learningMaterialsUploaded LearningMaterial[] @relation("LearningMaterialTeacher")

  coursesCreated Course[] @relation("CourseCreator")

  enrollments         Enrollment[] @relation("UserEnrollments")
  assignedEnrollments Enrollment[] @relation("EnrollmentAssignedBy")

  orders   Order[]
  payments Payment[]

  lessonProgress LessonProgress[]

  courseReviews CourseReview[]
  reviewReplies ReviewReply[]

  comments       Comment[]
  commentReplies CommentReply[]

  courseLikes CourseLike[]
  lessonLikes LessonLike[]
  wishlists   Wishlist[]

  certificates  Certificate[]
  notifications Notification[]

  auditLogs AuditLog[] @relation("AuditActor")

  muridAsWali MuridProfile[] @relation("WaliMuridRelation")

  @@index([status])
  @@index([createdById])
  @@index([deletedAt])
}
model Role {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  scope       RoleScope
  description String?
  isSystem    Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  permissions   RolePermission[]
  insidiaUsers UserInsidiaRole[]
  mitraUsers    UserMitraRole[]
  mitraRolePermissions MitraRolePermission[]

  @@index([scope])
  @@index([deletedAt])
}

model Permission {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  scope       RoleScope
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles RolePermission[]
  mitraRolePermissions MitraRolePermission[]

  @@index([scope])
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}
model MitraRolePermission {
  id           String @id @default(cuid())
  mitraId      String
  roleId       String
  permissionId String

  mitra      Mitra      @relation(fields: [mitraId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([mitraId, roleId, permissionId])
  @@index([mitraId])
  @@index([roleId])
  @@index([permissionId])
}
model UserInsidiaRole {
  id     String @id @default(cuid())
  userId String @unique
  roleId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@index([roleId])
}
model Mitra {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  type      MitraType
  status   AcademicStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  mitraRolePermissions MitraRolePermission[]
  members   UserMitraRole[]
  academicYears AcademicYear[]
  semesters Semester[]
  curricula Curriculum[]
  classes AcademicClass[]
  classGroups ClassGroup[]
  courses Course[]
  classGroupCourses ClassGroupCourse[]
  classGroupStudents ClassGroupStudent[]
  learningMaterials LearningMaterial[]
  
  @@index([type])
  @@index([deletedAt])
}
model UserMitraRole {
  id      String @id @default(cuid())
  userId  String @unique
  mitraId String
  roleId  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  mitra Mitra @relation(fields: [mitraId], references: [id], onDelete: Cascade)
  role  Role  @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, mitraId])
  @@index([userId])
  @@index([mitraId])
  @@index([roleId])
}
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String @map("provider_account_id")

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model AcademicYear {
  id        String         @id @default(cuid())
  mitraId   String
  name      String
  startDate DateTime
  endDate   DateTime
  status    AcademicStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  mitra             Mitra               @relation(fields: [mitraId], references: [id], onDelete: Cascade)
  semesters         Semester[]
  classes           AcademicClass[]
  classGroupCourses ClassGroupCourse[]
  classGroupStudents ClassGroupStudent[]

  @@index([mitraId])
  @@index([status])
  @@index([deletedAt])
  @@unique([mitraId, name])
}

model Semester {
  id             String         @id @default(cuid())
  mitraId        String
  academicYearId String
  name           String
  startDate      DateTime
  endDate        DateTime
  status         AcademicStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  mitra             Mitra               @relation(fields: [mitraId], references: [id], onDelete: Cascade)
  academicYear      AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classes           AcademicClass[]
  classGroupCourses ClassGroupCourse[]
  classGroupStudents ClassGroupStudent[]

  @@index([mitraId])
  @@index([academicYearId])
  @@index([status])
  @@index([deletedAt])
  @@unique([academicYearId, name])
}

model Curriculum {
  id          String         @id @default(cuid())
  mitraId     String
  name        String
  code        String?
  description String?        @db.Text
  status      AcademicStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  mitra   Mitra           @relation(fields: [mitraId], references: [id], onDelete: Cascade)
  courses Course[]
  classes AcademicClass[]

  @@index([mitraId])
  @@index([status])
  @@index([deletedAt])
  @@unique([mitraId, name])
  @@unique([mitraId, code])
}

model AcademicClass {
  id             String         @id @default(cuid())
  mitraId        String
  academicYearId String
  semesterId     String
  curriculumId   String
  name           String
  level          String
  status         AcademicStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  mitra        Mitra        @relation(fields: [mitraId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  semester     Semester     @relation(fields: [semesterId], references: [id], onDelete: Restrict)
  curriculum   Curriculum   @relation(fields: [curriculumId], references: [id], onDelete: Restrict)
  classGroups  ClassGroup[]

  @@index([mitraId])
  @@index([academicYearId])
  @@index([semesterId])
  @@index([curriculumId])
  @@index([status])
  @@index([deletedAt])
  @@unique([mitraId, academicYearId, semesterId, name])
}

model ClassGroup {
  id           String         @id @default(cuid())
  mitraId      String
  classId      String
  name         String
  waliKelasId  String?
  status       AcademicStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  mitra            Mitra               @relation(fields: [mitraId], references: [id], onDelete: Cascade)
  academicClass    AcademicClass       @relation(fields: [classId], references: [id], onDelete: Cascade)
  waliKelas        User?               @relation("ClassGroupHomeroomTeacher", fields: [waliKelasId], references: [id], onDelete: SetNull)
  classGroupCourses ClassGroupCourse[]
  classGroupStudents ClassGroupStudent[]
  learningMaterials LearningMaterial[]

  @@index([mitraId])
  @@index([classId])
  @@index([waliKelasId])
  @@index([status])
  @@index([deletedAt])
  @@unique([classId, name])
}

model ClassGroupCourse {
  id             String         @id @default(cuid())
  mitraId        String
  classGroupId   String
  courseId       String
  teacherId      String
  academicYearId String
  semesterId     String
  status         AcademicStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  mitra        Mitra        @relation(fields: [mitraId], references: [id], onDelete: Cascade)
  classGroup   ClassGroup   @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher      User         @relation("ClassGroupCourseTeacher", fields: [teacherId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  semester     Semester     @relation(fields: [semesterId], references: [id], onDelete: Restrict)

  @@index([mitraId])
  @@index([classGroupId])
  @@index([courseId])
  @@index([teacherId])
  @@index([academicYearId])
  @@index([semesterId])
  @@index([status])
  @@index([deletedAt])
  @@unique([classGroupId, courseId, academicYearId, semesterId])
}

model ClassGroupStudent {
  id             String         @id @default(cuid())
  mitraId        String
  classGroupId   String
  studentId      String
  academicYearId String
  semesterId     String
  status         AcademicStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  mitra        Mitra        @relation(fields: [mitraId], references: [id], onDelete: Cascade)
  classGroup   ClassGroup   @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  student      User         @relation("ClassGroupStudentUser", fields: [studentId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  semester     Semester     @relation(fields: [semesterId], references: [id], onDelete: Restrict)

  @@index([mitraId])
  @@index([classGroupId])
  @@index([studentId])
  @@index([academicYearId])
  @@index([semesterId])
  @@index([status])
  @@index([deletedAt])
  @@unique([classGroupId, studentId, academicYearId, semesterId])
}

model LearningMaterial {
  id           String         @id @default(cuid())
  mitraId      String
  classGroupId String
  courseId     String
  teacherId    String
  title        String
  description  String?        @db.Text
  filePath     String
  fileType     String
  fileSize     Int
  uploadedAt   DateTime       @default(now())
  status       AcademicStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  mitra      Mitra      @relation(fields: [mitraId], references: [id], onDelete: Cascade)
  classGroup ClassGroup @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher    User       @relation("LearningMaterialTeacher", fields: [teacherId], references: [id], onDelete: Restrict)

  @@index([mitraId])
  @@index([classGroupId])
  @@index([courseId])
  @@index([teacherId])
  @@index([status])
  @@index([deletedAt])
}

model AuthSession {
  id               String    @id
  userId           String
  refreshTokenHash String
  tokenVersion     Int       @default(1)
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model LoginEvent {
  id        String             @id @default(cuid())
  userId    String?
  email     String?
  provider  LoginEventProvider
  success   Boolean            @default(true)
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime           @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([email, createdAt])
}

model MentorProfile {
  id     String @id @default(cuid())
  userId String @unique

  expertise String?
  portfolio String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GuruProfile {
  id     String @id @default(cuid())
  userId String @unique

  nip     String?
  subject String?
  bio     String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AcademicProfile {
  id     String @id @default(cuid())
  userId String @unique

  position String?
  division String?
  note     String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MuridProfile {
  id     String @id @default(cuid())
  userId String @unique

  nis     String?
  kelas   String?
  jurusan String?

  waliId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  wali User? @relation("WaliMuridRelation", fields: [waliId], references: [id], onDelete: SetNull)

  @@index([waliId])
  @@index([kelas])
}

model WaliMuridProfile {
  id     String @id @default(cuid())
  userId String @unique

  pekerjaan String?
  alamat    String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id   String @id @default(cuid())
  name String
  slug String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courses Course[]

  @@index([name])
}

model Course {
  id        String @id @default(cuid())
  creatorId String
  mitraId String?
  curriculumId String?

  title       String
  slug        String  @unique
  code        String?
  subtitle    String?
  description String? @db.Text

  status CourseStatus @default(DRAFT)
  academicStatus AcademicStatus @default(ACTIVE)
  level  CourseLevel  @default(ALL_LEVEL)

  categoryId String?
  language   String  @default("id")

  price Decimal @default(0) @db.Decimal(12, 2)
salePrice Decimal? @db.Decimal(12, 2)
  isFree    Boolean  @default(false)

  requirements String[] @default([])
  outcomes     String[] @default([])
  targetUsers  String[] @default([])

  totalDurationSec Int @default(0)
  totalLessons     Int @default(0)

  publishedAt  DateTime?
  rejectedAt   DateTime?
  rejectReason String?
 scope RoleScope @default(INSIDIA)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  creator  User      @relation("CourseCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  mitra Mitra? @relation(fields: [mitraId], references: [id], onDelete: SetNull)
  curriculum Curriculum? @relation(fields: [curriculumId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  modules Module[]
  lessons Lesson[]
  media   Media[]
  classGroupCourses ClassGroupCourse[]
  learningMaterials LearningMaterial[]

  orderItems  OrderItem[]
  enrollments Enrollment[]

  reviews      CourseReview[]
  likes        CourseLike[]
  wishlists    Wishlist[]
  certificates Certificate[]

  @@index([creatorId])
  @@index([mitraId])
  @@index([curriculumId])
  @@index([categoryId])
  @@index([status])
  @@index([academicStatus])
  @@index([deletedAt])
  @@unique([mitraId, code])
}

model Module {
  id       String @id @default(cuid())
  courseId String

  title     String
  summary   String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  media   Media[]

@@unique([courseId, sortOrder])
}

model Lesson {
  id       String @id @default(cuid())
  courseId String
  moduleId String

  title       String
  slug        String
  description String?
  type        LessonType @default(VIDEO)

contentJson Json?
contentHtml String? @db.Text

  sortOrder   Int     @default(0)
  isPreview   Boolean @default(false)
  isPublished Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  media    Media[]
  progress LessonProgress[]
  comments Comment[]
  likes    LessonLike[]

  @@unique([courseId, slug])
  @@index([courseId])
 @@unique([moduleId, sortOrder])
  @@index([deletedAt])
}

model Media {
  id String @id @default(cuid())

  type      MediaType
  ownerType MediaOwnerType

  url         String
  publicId    String?
  filename    String?
  mimeType    String?
  sizeBytes   Int?
  durationSec Int?

  alt       String?
  caption   String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)

  courseId  String?
  moduleId  String?
  lessonId  String?
  reviewId  String?
  commentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course?       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module  Module?       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lesson  Lesson?       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  review  CourseReview? @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  comment Comment?      @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([courseId, sortOrder])
  @@index([moduleId, sortOrder])
  @@index([lessonId, sortOrder])
  @@index([reviewId])
  @@index([commentId])
  @@index([ownerType])
}

model Order {
  id   String @id @default(cuid())
  code String @unique

  userId String
  status OrderStatus @default(PENDING_PAYMENT)

  subtotal Decimal @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)

  couponCode String?
  notes      String?

  expiresAt   DateTime?
  paidAt      DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  items       OrderItem[]
  payment     Payment?
  refund      RefundRequest?
  enrollments Enrollment[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id       String @id @default(cuid())
  orderId  String
  courseId String

  titleSnapshot String
  price         Decimal @db.Decimal(12, 2)
  discount      Decimal @default(0) @db.Decimal(12, 2)
  lineTotal     Decimal @db.Decimal(12, 2)

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Restrict)

  @@unique([orderId, courseId])
  @@index([courseId])
}

model Payment {
  id      String @id @default(cuid())
  orderId String @unique
  userId  String

  method PaymentMethod
  status PaymentStatus @default(PENDING)
  amount Decimal       @db.Decimal(12, 2)

  gateway              PaymentGateway
  channelCode          String?
  gatewayReference     String?        @unique
  paymentUrl           String?
  gatewayStatusCode    String?
  gatewayStatusMessage String?

  callbackPayload Json?
  callbackAt      DateTime?

  proofUrl String?
  paidAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([status, createdAt])
  @@index([method])
}

model Enrollment {
  id String @id @default(cuid())

  userId   String
  courseId String
  orderId  String?

  source EnrollmentSource @default(PURCHASED)
  status EnrollmentStatus @default(ACTIVE)

  assignedById String?
  assignedAt   DateTime?

  startedAt   DateTime  @default(now())
  expiredAt   DateTime?
  completedAt DateTime?

  progressPercent Decimal @default(0) @db.Decimal(5, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation("UserEnrollments", fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  assignedBy User? @relation("EnrollmentAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([orderId])
  @@index([source])
  @@index([status])
  @@index([assignedById])
}

model LessonProgress {
  id String @id @default(cuid())

  userId   String
  lessonId String

  watchedSec   Int       @default(0)
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  lastAccessAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
  @@index([userId, updatedAt])
}

model Comment {
  id String @id @default(cuid())

  lessonId String
  userId   String

  message String        @db.Text
  status  CommentStatus @default(PUBLISHED)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  replies CommentReply[]
  media   Media[]

  @@index([lessonId, createdAt])
  @@index([userId, createdAt])
  @@index([status])
  @@index([deletedAt])
}

model CommentReply {
  id String @id @default(cuid())

  commentId String
  userId    String

  message String @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([commentId, createdAt])
  @@index([userId, createdAt])
  @@index([deletedAt])
}

model CourseReview {
  id String @id @default(cuid())

  courseId String
  userId   String

  rating  Int
  comment String?      @db.Text
  status  ReviewStatus @default(PENDING)

  moderationReason String?
  moderatedAt      DateTime?
  moderatedBy      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  replies ReviewReply[]
  media   Media[]

  @@unique([courseId, userId])
  @@index([courseId, status, createdAt])
  @@index([userId, createdAt])
  @@index([deletedAt])
}

model ReviewReply {
  id String @id @default(cuid())

  reviewId String
  actorId  String

  message String @db.Text

  createdAt DateTime @default(now())

  review CourseReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  actor  User         @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([reviewId, createdAt])
  @@index([actorId, createdAt])
}

model CourseLike {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, createdAt])
}

model LessonLike {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId, createdAt])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model Coupon {
  id   String @id @default(cuid())
  code String @unique
  name String

  discountPercent Int?
  discountAmount  Decimal? @db.Decimal(12, 2)

  maxUsage  Int?
  usedCount Int  @default(0)

  startsAt DateTime?
  endsAt   DateTime?
  isActive Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([startsAt, endsAt])
}

model RefundRequest {
  id      String @id @default(cuid())
  orderId String @unique

  reason       String
  reasonDetail String? @db.Text
  status       String  @default("REQUESTED")

  amount Decimal? @db.Decimal(12, 2)
  note   String?  @db.Text

  requestedAt DateTime  @default(now())
  reviewedAt  DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
}

model Certificate {
  id String @id @default(cuid())

  userId   String
  courseId String

  certificateNo   String   @unique
  issuedAt        DateTime @default(now())
  fileUrl         String?
  verificationUrl String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

model Notification {
  id     String @id @default(cuid())
  userId String

  type    NotificationType
  title   String
  message String?
  data    Json?

  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([type, createdAt])
}
model BulkUploadJob {
  id          String              @id @default(uuid())
  fileName    String
  uploadedBy  String?
  status      BulkUploadJobStatus @default(VALIDATED)

  totalRows   Int @default(0)
  validRows   Int @default(0)
  invalidRows Int @default(0)
  successRows Int @default(0)
  failedRows  Int @default(0)

  rows        BulkUploadRow[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BulkUploadRow {
  id        String              @id @default(uuid())
  jobId     String
  rowNumber Int

  rawData   Json
  errors    Json?

  status    BulkUploadRowStatus

  job       BulkUploadJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([status])
}
model AuditLog {
  id String @id @default(cuid())

  actorId String?
  action  AuditAction

  entity   String
  entityId String?

  metadata  Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([entity, entityId])
}
